{
  "name": "atshacker-remotion",
  "version": "1.0.0",
  "description": "Remotion pipeline for ATSHacker captioned vertical short-form videos (TikTok/Reels/Shorts).",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render ScoreReveal out/score-reveal.mp4",
    "render:signal": "remotion render SignalViralAd out/signal-viral-mascot-audio.mp4 --props=props_signal_viral_preset.json",
    "render:breakthrough": "remotion render SignalBreakthroughAd out/signal-breakthrough-cinematic.mp4 --props=props_signal_breakthrough_preset.json",
    "render:breakthrough:draft": "remotion render SignalBreakthroughAd out/signal-filter-breakthrough-quiet-draft.mp4 --props=props_signal_filter_breakthrough_draft.json",
    "render:breakthrough:studio": "remotion render SignalBreakthroughAd out/signal-filter-breakthrough-studio.mp4 --props=props_signal_studio_breakthrough.json",
    "render:crime-scene": "remotion render ResumeCrimeScene out/resume-crime-scene-demand-gen.mp4 --props=props_resume_crime_scene.json",
    "render:episode": "remotion render TeardownEpisode out/daily-teardown-episode.mp4",
    "render:episode:review": "remotion render TeardownEpisodeReviewCut out/daily-teardown-episode-review-cut.mp4",
    "render:thumbnail": "remotion still SignalThumbnail out/daily-thumbnail.png",
    "render:daily:short1:studio": "remotion render ResumeCrimeScene out/daily-your-ai-resume-has-linkedin-breath-studio.mp4 --props=props_daily_2026-06-28_ai-resumes-all-sound-the-same-so-recruiters-search-for-proof_short_1.json",
    "render:daily:short2:studio": "remotion render ResumeCrimeScene out/daily-one-bullet-fix-studio.mp4 --props=props_daily_2026-06-28_ai-resumes-all-sound-the-same-so-recruiters-search-for-proof_short_2.json",
    "render:daily:short3:studio": "remotion render ResumeCrimeScene out/daily-ats-myth-lab-studio.mp4 --props=props_daily_2026-06-28_ai-resumes-all-sound-the-same-so-recruiters-search-for-proof_short_3.json",
    "render:daily:shorts:studio": "npm run render:daily:short1:studio && npm run render:daily:short2:studio && npm run render:daily:short3:studio",
    "qc:daily:shorts": "node scripts/qc_daily_studio_shorts.mjs",
    "voiceover:episode": "node scripts/generate_episode_voiceover.mjs",
    "bundle": "remotion bundle",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.483",
    "@remotion/media": "^4.0.483",
    "@remotion/media-parser": "4.0.483",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.483",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.5.4"
  }
}
